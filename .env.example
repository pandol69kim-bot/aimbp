# Database
DATABASE_URL=postgresql+asyncpg://aimbp:aimbp1234@db:5432/aimbp
DATABASE_URL_SYNC=postgresql://aimbp:aimbp1234@db:5432/aimbp

# JWT Auth
SECRET_KEY=your-secret-key-change-in-production-must-be-32-chars-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Suno (mock)
SUNO_API_KEY=your-suno-api-key

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=aimbp-files

# CORS
CORS_ORIGINS=http://localhost:3000

# App
APP_ENV=development
DEBUG=true
